# Son identificadores públicos: Expo los incorpora al bundle de la app.
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=g0vemv0z
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=moodmatch_avatars

# Reporte de errores (Sentry, proyecto de la app — NUNCA el DSN del backend:
# todo lo que empieza con EXPO_PUBLIC_ viaja dentro del bundle instalado).
# Vacío = Sentry no se inicializa, que es lo esperado en desarrollo.
EXPO_PUBLIC_SENTRY_DSN=

# Solo para subir los source maps durante el build de EAS, de modo que los
# stack traces sean legibles en vez de código minificado. No se incrusta en el
# bundle: se configura como secret de EAS, no acá.
SENTRY_AUTH_TOKEN=
