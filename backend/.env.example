# Copia este archivo a backend/.env y completa los valores. .env está en
# .gitignore y NUNCA se commitea; en producción (Render) las variables se
# configuran en el dashboard del servicio, no en archivos.

# PostgreSQL (Neon)
DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require"

# Puerto del servidor Express (opcional, default 3000)
PORT=3000

# Firma de los JWT de sesión (opcional en dev: cae a un default de desarrollo;
# en producción debe estar definida)
JWT_SECRET=""

# REQUERIDA para el chat con IA (Fase 8). Se obtiene gratis en
# https://aistudio.google.com/apikey — capa gratuita de Gemini Flash.
# Nunca va en el frontend ni en el repositorio. Ver CONTRATO-GEMINI.md.
GEMINI_API_KEY=""

# Nombre público del cloud que aloja las fotos de perfil en Cloudinary.
CLOUDINARY_CLOUD_NAME="g0vemv0z"
