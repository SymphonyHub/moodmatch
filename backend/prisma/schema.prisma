generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MoodType {
  FELIZ
  TRISTE
  ANSIOSO
  CALMADO
  ENOJADO
  NEUTRO
}

model User {
  id              Int          @id @default(autoincrement())
  nombre          String
  email           String       @unique
  passwordHash    String
  qrCode          String       @unique @default(uuid())
  themePreference String?
  customTheme     Json?
  avatarUrl       String?
  perfilPersonalidad Json?
  expoPushToken          String?
  notificationPreferences Json?
  racha           Int          @default(0)
  createdAt       DateTime     @default(now())

  moodEntries    MoodEntry[]
  friendsAdded   Friendship[] @relation("FriendshipUser")
  friendsOf      Friendship[] @relation("FriendshipFriend")
  cheersSent     Cheer[]      @relation("CheerFrom")
  cheersReceived Cheer[]      @relation("CheerTo")
}

model MoodEntry {
  id        Int        @id @default(autoincrement())
  userId    Int
  clientId  String?    @unique
  moodType  MoodType
  nota      String?
  createdAt DateTime   @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestions Suggestion[]
}

model Activity {
  id          Int    @id @default(autoincrement())
  nombre      String
  descripcion String
  categoria   String

  moodActivities MoodActivity[]
  suggestions    Suggestion[]
}

model MoodActivity {
  moodType   MoodType
  activityId Int

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([moodType, activityId])
}

model Suggestion {
  id          Int      @id @default(autoincrement())
  moodEntryId Int
  activityId  Int
  createdAt   DateTime @default(now())

  moodEntry MoodEntry @relation(fields: [moodEntryId], references: [id], onDelete: Cascade)
  activity  Activity  @relation(fields: [activityId], references: [id])
}

model Friendship {
  id        Int      @id @default(autoincrement())
  userId    Int
  friendId  Int
  createdAt DateTime @default(now())

  user   User @relation("FriendshipUser",   fields: [userId],   references: [id], onDelete: Cascade)
  friend User @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  mascota MascotaAmistad?

  @@unique([userId, friendId])
}

model Cheer {
  id         Int      @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  message    String
  seen       Boolean  @default(false)
  reacciones Json?
  createdAt  DateTime @default(now())

  fromUser User @relation("CheerFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("CheerTo",   fields: [toUserId],   references: [id], onDelete: Cascade)
}

model MascotaAmistad {
  id          String     @id @default(cuid())
  amistadId   Int        @unique
  amistad     Friendship @relation(fields: [amistadId], references: [id], onDelete: Cascade)
  nombre      String
  nivelCarino Int        @default(0)
  ultimoCuidadoUsuario1 DateTime?
  ultimoCuidadoUsuario2 DateTime?
  retoCooperativo       Json?
  nombrePropuesto       String?
  historialHitos        Json?
  etapa                   Int      @default(1)
  accesorioCabeza         String?
  accesorioColor          String?
  accesoriosDesbloqueados Json?
  activa                  Boolean  @default(true)
  invitacionEstado        String   @default("pendiente")
  invitadaPor             Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
